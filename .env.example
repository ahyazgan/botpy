# ── Kripto haber-trade (AKTİF) ──────────────────────────────────────────
# Claude ile akıllı haber puanlaması için (opsiyonel). Yoksa kural-tabanlı çalışır.
# https://console.anthropic.com adresinden alınır.
ANTHROPIC_API_KEY=

# CANLI Binance işlemi için (opsiyonel). YOKSA paper (simülasyon) modu çalışır.
# ⚠️ GÜVENLİK: Bu anahtarı oluştururken "Para Çekme (Withdrawal)" iznini KAPALI bırak!
# Sadece "Spot/Futures İşlem" izni yeterli. IP kısıtlaması da eklemen önerilir.
BINANCE_API_KEY=
BINANCE_SECRET=

# ── Polymarket CLOB (eski, aktif değil) ─────────────────────────────────
# Gerçek işlem açmak için gerekli (PAPER_MODE=False)
# https://docs.polymarket.com adresinden edinilir
PRIVATE_KEY=
FUNDER_ADDRESS=
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# Güvenlik: 1/true ise arb_bot.py gerçek emir GÖNDERMEZ (simülasyon).
# Bu modda yukarıdaki anahtarlar boş olabilir.
ARB_DRY_RUN=1

# Opsiyonel uzak bildirimler (boşsa devre dışı). Tetikleyiciler:
#   • news_bot.py → güçlü haber (güç ≥ eşik) + oto-işlem açılış/kapanış
#   • arb_bot.py  → arbitraj fırsatı
# winotify (Windows masaüstü) yalnızca bilgisayar başındayken çalışır; bu kanal
# sinyalleri telefona/uzağa ulaştırır.
# Telegram: @BotFather'dan token al, chat_id'yi @userinfobot ile öğren.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Opsiyonel: SQLite veritabanı yolu (varsayılan botpy.db)
BOTPY_DB=
